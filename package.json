{
  "name": "bsv-academy-mcp",
  "version": "1.0.0",
  "description": "MCP server providing access to BSV Academy knowledge base — courses, concepts, and searchable content from hub.bsvblockchain.org",
  "type": "module",
  "bin": {
    "bsv-academy-mcp": "./dist/server.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx src/server.ts",
    "scrape": "tsx src/scrape.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "bsv",
    "blockchain",
    "academy",
    "bitcoin",
    "model-context-protocol"
  ],
  "author": "MatiasJF",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MatiasJF/bsv-academy-mcp.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "axios": "^1.7.0",
    "cheerio": "^1.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0"
  }
}
